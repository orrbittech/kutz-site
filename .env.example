#clerk publishable key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

#clerk secret key
CLERK_SECRET_KEY=

# Nest API origin — must match the `PORT` in server/.env (e.g. http://localhost:4500).
NEXT_PUBLIC_API_URL=http://localhost:4500

#canonical site URL for SEO (sitemap, JSON-LD, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe.js (test mode: pk_test_… from Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
