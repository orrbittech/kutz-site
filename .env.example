# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Nest API — must match server PORT locally; on Railway use your deployed API URL (trailing slash ok)
NEXT_PUBLIC_API_URL=http://localhost:4500
API_URL=http://localhost:4500

# Public site URL (SEO, sitemap). Local: http://localhost:3000 — Railway: https://YOUR_WEB_SERVICE.up.railway.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Error page — optional “report to developer” actions (mailto + WhatsApp prefilled text)
NEXT_PUBLIC_ERROR_REPORT_EMAIL=
# E.164 digits only, no + (e.g. 27739590288 for South Africa)
NEXT_PUBLIC_ERROR_REPORT_WHATSAPP=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Production on Railway: NODE_ENV=production
NODE_ENV=development

# Do not set NODE_OPTIONS=--max-old-space-size=384 on this app — it breaks `next build`.
# The `yarn build` script sets a higher heap for Next.js. Omit NODE_OPTIONS unless you know you need it.
